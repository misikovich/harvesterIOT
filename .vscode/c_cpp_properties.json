{
    "configurations": [
        {
            "name": "Linux-Clang",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/.pio/libdeps/<env>/**",
                "${workspaceFolder}/.pio/packages/**"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/.pio/libdeps/<env>",
                    "${workspaceFolder}/.pio/packages"
                ]
            },
            "intelliSenseMode": "clang-x64",
            "compilerPath": "/usr/bin/clang",
            "cStandard": "c11",
            "cppStandard": "c++17"
        }
    ],
    "version": 4
}